{
  "name": "@illuma/lifecycle",
  "description": "Boot & shutdown ordering tokens for @illuma/core DI apps — async init, two-phase graceful drain + teardown",
  "author": "bebrasmell",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/git-illuma/lifecycle.git"
  },
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./rxjs": {
      "types": "./dist/rxjs.d.ts",
      "import": "./dist/rxjs.js",
      "require": "./dist/rxjs.cjs"
    }
  },
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "illuma",
    "di",
    "dependency-injection",
    "lifecycle",
    "async-init",
    "graceful-shutdown",
    "drain",
    "tokens"
  ],
  "scripts": {
    "test": "vitest run",
    "test:badges": "vitest run --coverage && make-coverage-badge --report-path ./artifacts/coverage/coverage-summary.json --output-path ./badges/coverage.svg",
    "build": "tsup",
    "lint": "biome check",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@illuma/core": ">=2.3.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@illuma/core": "^2.3.1",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "4.0.18",
    "make-coverage-badge": "1.2.0",
    "rxjs": "7.8.2",
    "terser": "5.48.0",
    "tsup": "8.5.1",
    "typescript": "5.9.2",
    "vitest": "4.0.18"
  },
  "packageManager": "bun@1.3.6"
}
