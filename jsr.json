{
  "name": "@illuma/lifecycle",
  "description": "Boot & shutdown ordering tokens for @illuma/core DI apps — async init, two-phase graceful drain + teardown",
  "author": "bebrasmell",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/git-illuma/lifecycle.git"
  },
  "version": "0.1.0",
  "license": "MIT",
  "publish": {
    "include": [
      "src/**/*",
      "README.md"
    ],
    "exclude": [
      "docs/**/*",
      ".vscode/**/*",
      ".github/**/*",
      "artifacts/**/*",
      "node_modules/**/*",
      "dist/**/*",
      ".editorconfig",
      ".gitignore",
      "tsconfig.json",
      "tsconfig.spec.json",
      "biome.json",
      "CHANGELOG.md",
      "CONTRIBUTING.md",
      "tsup.config.ts",
      "vitest.config.ts",
      "src/test-setup.ts",
      "**/*.test.ts",
      "**/*.spec.ts"
    ]
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
